{
  "name": "offerly-copilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --host 0.0.0.0 --port 1420",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc && vite build",
    "build:api": "npm run build --workspace=apps/api",
    "start:api": "npm run start --workspace=apps/api",
    "test:api": "npm run test --workspace=apps/api",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "axios": "^1.15.2",
    "openai": "^6.34.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
