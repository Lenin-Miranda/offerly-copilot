{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Offerly",
  "version": "0.1.0",
  "identifier": "npm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Offerly",
        "width": 92,
        "height": 92,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
